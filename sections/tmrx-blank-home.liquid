{% liquid
  assign hero_image_alt = section.settings.heading
  if section.settings.hero_image.alt != blank
    assign hero_image_alt = section.settings.hero_image.alt
  endif
%}

<section class="tmrx-foundation">
  <div class="tmrx-foundation__inner">
    <div class="tmrx-foundation__content">
      {% if section.settings.proof_text != blank %}
        <div class="tmrx-foundation__proof">
          <span class="tmrx-foundation__avatars" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span>{{ section.settings.proof_text }}</span>
        </div>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <p class="tmrx-foundation__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="tmrx-foundation__title">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.note != blank %}
        <p class="tmrx-foundation__note">{{ section.settings.note }}</p>
      {% endif %}

      <div class="tmrx-foundation__actions">
        <a class="tmrx-button tmrx-button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
          {{ section.settings.primary_label }}
        </a>
        <a class="tmrx-button" href="{{ section.settings.secondary_link | default: routes.search_url }}">
          {{ section.settings.secondary_label }}
        </a>
      </div>
    </div>

    <div class="tmrx-foundation__media{% unless section.settings.hero_image %} tmrx-placeholder-media{% endunless %}">
      {% if section.settings.hero_image %}
        {{ section.settings.hero_image | image_url: width: 1400 | image_tag: loading: 'eager', fetchpriority: 'high', alt: hero_image_alt }}
      {% endif %}
    </div>

    <div class="tmrx-foundation__trust" aria-label="Store standards">
      <div class="tmrx-foundation__trust-item">
        <span aria-hidden="true">01</span>
        <p>{{ section.settings.trust_1 }}</p>
      </div>
      <div class="tmrx-foundation__trust-item">
        <span aria-hidden="true">02</span>
        <p>{{ section.settings.trust_2 }}</p>
      </div>
      <div class="tmrx-foundation__trust-item">
        <span aria-hidden="true">03</span>
        <p>{{ section.settings.trust_3 }}</p>
      </div>
      <div class="tmrx-foundation__trust-item">
        <span aria-hidden="true">04</span>
        <p>{{ section.settings.trust_4 }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "TMRX blank home",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Practitioner-grade nutraceuticals"
    },
    {
      "type": "text",
      "id": "proof_text",
      "label": "Proof text",
      "default": "Professional-grade wellness support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hold your supplements to a higher standard."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Note",
      "default": "Reach your health and performance goals with clean, purpose-built formulas for strength, recovery, daily protein, hormone support, and foundational wellness."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop supplements"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Find my supplement routine"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Clean, purpose-built formulas"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Transparent ingredient standards"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "Practitioner-grade support"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Trust item 4",
      "default": "Built for daily optimization"
    }
  ],
  "presets": [
    {
      "name": "TMRX blank home"
    }
  ]
}
{% endschema %}
