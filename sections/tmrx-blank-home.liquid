<section class="tmrx-foundation">
  <div class="tmrx-foundation__inner">
    <div class="tmrx-foundation__content">
    {% if section.settings.eyebrow != blank %}
      <p class="tmrx-foundation__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="tmrx-foundation__title">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.note != blank %}
      <p class="tmrx-foundation__note">{{ section.settings.note }}</p>
    {% endif %}

      <div class="tmrx-foundation__actions">
        <a class="tmrx-button tmrx-button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
          {{ section.settings.primary_label }}
        </a>
        <a class="tmrx-button" href="{{ section.settings.secondary_link | default: routes.search_url }}">
          {{ section.settings.secondary_label }}
        </a>
      </div>
    </div>

    <div class="tmrx-foundation__media tmrx-placeholder-media" aria-hidden="true"></div>
  </div>
</section>

{% schema %}
{
  "name": "TMRX blank home",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Practitioner-grade nutraceuticals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Next level optimization starts here"
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Note",
      "default": "Shop clean, purpose-built formulas for strength, recovery, daily protein, hormone support, and foundational wellness."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop all products"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Find your formula"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "TMRX blank home"
    }
  ]
}
{% endschema %}
